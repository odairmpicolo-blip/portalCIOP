# Copie para ~/.config/ciop-portal/incidentes.env e preencha os valores.
# cp scripts/incidentes.env.example ~/.config/ciop-portal/incidentes.env

CIOP_INCIDENTES_USUARIO=
CIOP_INCIDENTES_SENHA=

# Repositório principal (portal-teste). Padrão: pasta do portal onde o script está instalado.
# CIOP_PORTAL_ROOT=/Users/SEU_USUARIO/portal-teste

# Repositório de produção (opcional). Se definido, o JSON também é publicado no portalCIOP.
CIOP_PORTAL_PROD=/Users/odairpicolo/portalCIOP
