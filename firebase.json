{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "scripts/**",
      ".github/**",
      "package.json",
      "package-lock.json",
      "firestore.rules",
      ".cursor/**",
      "portal-app/**"
    ],
    "rewrites": [
      {
        "source": "/app/**",
        "destination": "/app/index.html"
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}
