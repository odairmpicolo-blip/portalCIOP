rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null && request.auth.token.email != null;
    }

    function email() {
      // Auth pode devolver maiúsculas; membros do chat são gravados em minúsculas.
      return request.auth.token.email.lower();
    }

    function perfilAtual() {
      return exists(/databases/$(database)/documents/usuarios/$(email()))
        ? get(/databases/$(database)/documents/usuarios/$(email())).data.perfil
        : "";
    }

    function perfilBuscaAtual() {
      return exists(/databases/$(database)/documents/usuarios/$(email()))
        ? get(/databases/$(database)/documents/usuarios/$(email())).data.perfilBusca
        : "";
    }

    function gestor() {
      return signedIn() && perfilAtual() in ['Administrador', 'Supervisor', 'Gerência', 'Gerencia'];
    }

    function podePostarAviso() {
      return signedIn() && perfilAtual() in ['Administrador', 'Supervisor', 'Gerência', 'Gerencia', 'Secretária', 'Secretaria'];
    }

    function listaTemUsuario(lista) {
      return lista is list && email() in lista;
    }

    function listaTemPerfil(lista) {
      return lista is list && perfilAtual() in lista;
    }

    function listaTemPerfilBusca(lista) {
      return lista is list && perfilBuscaAtual() != "" && perfilBuscaAtual() in lista;
    }

    function donoPortal() {
      return signedIn() && email() == 'odair.marin@icloud.com';
    }

    function eMembroSala(salaId) {
      // Preferência: id da sala (sempre com e-mails em minúsculas) + lista membros.
      return signedIn() && (
        email() in salaId.split('__')
        || (
          resource.data.membros is list
          && (email() in resource.data.membros || request.auth.token.email in resource.data.membros)
        )
      );
    }

    function seraMembroSala() {
      return signedIn()
        && request.resource.data.membros is list
        && email() in request.resource.data.membros;
    }

    function podeLerMensagensSala(salaId) {
      return donoPortal()
        || (signedIn() && email() in salaId.split('__'))
        || (
          signedIn()
          && get(/databases/$(database)/documents/chatSalas/$(salaId)).data.membros is list
          && (
            email() in get(/databases/$(database)/documents/chatSalas/$(salaId)).data.membros
            || request.auth.token.email in get(/databases/$(database)/documents/chatSalas/$(salaId)).data.membros
          )
        );
    }

    match /avisos/{avisoId} {
      allow read: if signedIn() && (
        podePostarAviso() ||
        resource.data.publico == true ||
        listaTemUsuario(resource.data.usuarios) ||
        listaTemPerfil(resource.data.perfisRegra) ||
        listaTemPerfil(resource.data.perfis) ||
        listaTemPerfilBusca(resource.data.perfisBusca)
      );
      allow create, update, delete: if podePostarAviso();
    }

    match /avisosPorUsuario/{userEmail}/itens/{avisoId} {
      allow read: if signedIn() && userEmail == email();
      allow create, update, delete: if podePostarAviso();
    }

    match /usuarios/{userEmail} {
      allow read: if signedIn() && (userEmail == email() || gestor() || podePostarAviso());
      allow create, update: if gestor();
      allow delete: if gestor();
    }

    match /config/{docId} {
      allow read: if signedIn();
      allow write: if donoPortal();
    }

    match /presenca/{userEmail} {
      allow read: if signedIn();
      allow create, update: if signedIn() && userEmail == email();
      allow delete: if signedIn() && (userEmail == email() || donoPortal());
    }

    match /chatSalas/{salaId} {
      allow read: if donoPortal() || eMembroSala(salaId);
      allow create: if seraMembroSala()
        && request.resource.data.tipo == 'dm'
        && request.resource.data.membros.size() == 2;
      allow update: if donoPortal() || eMembroSala(salaId);
      allow delete: if donoPortal();

      match /mensagens/{msgId} {
        allow read: if podeLerMensagensSala(salaId);
        allow create: if signedIn()
          && request.resource.data.de == email()
          && request.resource.data.texto is string
          && request.resource.data.texto.size() > 0
          && request.resource.data.texto.size() <= 4000
          && (
            email() in salaId.split('__')
            || (
              get(/databases/$(database)/documents/chatSalas/$(salaId)).data.membros is list
              && (
                email() in get(/databases/$(database)/documents/chatSalas/$(salaId)).data.membros
                || request.auth.token.email in get(/databases/$(database)/documents/chatSalas/$(salaId)).data.membros
              )
            )
          );
        allow update, delete: if donoPortal();
      }
    }
  }
}
