rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null && request.auth.token.email != null;
    }

    function email() {
      return request.auth.token.email;
    }

    function bootstrapGestor() {
      return email() in ['admin@ciop.com.br', 'supervisor@ciop.com.br', 'odair.marin@icloud.com'];
    }

    function perfilAtual() {
      return exists(/databases/$(database)/documents/usuarios/$(email()))
        ? get(/databases/$(database)/documents/usuarios/$(email())).data.perfil
        : "";
    }

    function gestor() {
      return signedIn() && (bootstrapGestor() || perfilAtual() in ['Administrador', 'Supervisor', 'Gerência', 'Gerencia']);
    }

    function podePostarAviso() {
      return signedIn() && (bootstrapGestor() || perfilAtual() in ['Administrador', 'Supervisor', 'Gerência', 'Gerencia', 'Secretária', 'Secretaria']);
    }

    function listaTemUsuario(lista) {
      return lista is list && email() in lista;
    }

    function listaTemPerfil(lista) {
      return lista is list && perfilAtual() in lista;
    }

    function perfilFolhaServico() {
      return signedIn() && (
        bootstrapGestor() ||
        perfilAtual() in ['Administrador', 'Supervisor', 'Analista']
      );
    }

    match /folhaServicoDias/{dataIso} {
      allow read: if perfilFolhaServico();
      allow create, update: if perfilFolhaServico();
      allow delete: if gestor();

      match /linhas/{linhaId} {
        allow read: if perfilFolhaServico();
        allow create, update: if perfilFolhaServico()
          && request.resource.data.atualizadoPor == email()
          && linhaId == string(request.resource.data._row);
        allow delete: if gestor();
      }
    }

    match /avisos/{avisoId} {
      allow read: if signedIn() && (
        podePostarAviso() ||
        resource.data.publico == true ||
        listaTemUsuario(resource.data.usuarios) ||
        listaTemPerfil(resource.data.perfisRegra)
      );
      allow create, update, delete: if podePostarAviso();
    }

    match /avisosPorUsuario/{userEmail}/itens/{avisoId} {
      allow read: if signedIn() && userEmail == email();
      allow create, update, delete: if podePostarAviso();
    }

    match /usuarios/{userEmail} {
      allow read: if signedIn() && (userEmail == email() || gestor() || podePostarAviso());
      allow create, update: if gestor();
      allow delete: if gestor();
    }
  }
}
