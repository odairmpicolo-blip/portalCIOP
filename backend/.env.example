# --- Aurora DSQL (recomendado) ---
# Endpoint: {DSQL_CLUSTER_ID}.dsql.{DSQL_REGION}.on.aws
DSQL_CLUSTER_ID=ort34httzig7iktrneb4ytcy5u
DSQL_REGION=sa-east-1
DSQL_USER=admin

# Credenciais AWS (IAM) via AWS CLI, variáveis de ambiente ou ~/.aws/credentials
# Permissões: dsql:DbConnect, dsql:DbConnectAdmin (para DDL)

# --- RDS/Aurora PostgreSQL tradicional (alternativa) ---
# Deixe DSQL_CLUSTER_ID vazio e use DATABASE_URL:
# DATABASE_URL=postgresql://portal_user:SENHA@SEU-HOST.rds.amazonaws.com:5432/portalciop

PORT=3000

# Origens permitidas (portal estático). Separe por vírgula.
CORS_ORIGINS=https://www.portalciop.com.br,https://portalciop.com.br,http://localhost:5173,http://127.0.0.1:5500,http://localhost:3000

# Chave para jobs GitHub Actions (importação). Header: X-Portal-Api-Key
PORTAL_API_KEY=

# Firebase Admin — caminho do JSON da service account (mesmo projeto portal-ciop)
GOOGLE_APPLICATION_CREDENTIALS=../.secrets/serviceAccount.json
